OPENAI_API_KEY=sk-proj....
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
PGVECTOR_COLLECTION=default
PGVECTOR_CONNECTION=postgresql+psycopg://raguser:ragpass@localhost:5432/ragdb

#PGVECTOR_CONNECTION=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

JWT_SECRET=change-me-in-production

# Comma-separated list of allowed CORS origins.
# Set to your domain once you have one: ALLOWED_ORIGINS=https://yourdomain.com
# Leave as * only for local development.
ALLOWED_ORIGINS=*

# JWT token lifetime in minutes. 60 is a reasonable default.
# Shorter = more secure (stolen tokens expire sooner). Longer = fewer logins.
ACCESS_TOKEN_EXPIRE_MINUTES=60
